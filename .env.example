# Copiá este archivo como .env.local y completá los valores

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# WhatsApp Cloud API (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Webhook verification (inventá cualquier string secreto)
WHATSAPP_VERIFY_TOKEN=mi-token-secreto-aqui

# Sesiones (inventá un string largo y aleatorio)
SESSION_SECRET=cambia-esto-por-un-string-largo-y-aleatorio

# Servidor
PORT=3000
